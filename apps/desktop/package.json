{
  "name": "@brett/desktop",
  "version": "0.1.0",
  "description": "Brett desktop app",
  "author": "Brent Barkman",
  "private": true,
  "main": "dist/electron/main.js",
  "build": {
    "appId": "com.brett.app",
    "productName": "Brett",
    "npmRebuild": false,
    "files": [
      "dist/electron/**/*",
      "dist/renderer/**/*",
      "!dist/renderer/videos/**",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/tray-*.png",
        "to": "resources"
      }
    ],
    "mac": {
      "target": "zip",
      "icon": "resources/icon.icns"
    },
    "publish": {
      "provider": "generic",
      "url": "https://placeholder.invalid/releases"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"tsc -p tsconfig.electron.json -w\" \"electron .\"",
    "electron:build": "vite build && tsc -p tsconfig.electron.json && node -e \"require('fs').writeFileSync('dist/electron/api-config.json', JSON.stringify({apiURL: process.env.VITE_API_URL || 'http://localhost:3001', storageEndpoint: process.env.STORAGE_ENDPOINT || '', storageBucket: process.env.STORAGE_BUCKET || 'brett', releaseStorageEndpoint: process.env.RELEASE_STORAGE_ENDPOINT || '', releaseStorageBucket: process.env.RELEASE_STORAGE_BUCKET || 'brett-releases'}))\" && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.5.6",
    "@brett/business": "workspace:*",
    "@brett/types": "workspace:*",
    "@brett/ui": "workspace:*",
    "@brett/utils": "workspace:*",
    "@carrot-kpi/switzer-font": "^0.1.0",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@tanstack/react-query": "^5.60.0",
    "better-auth": "^1.2.7",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.0",
    "electron": "28.3.3",
    "electron-builder": "^26.8.1",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.3.3",
    "vite": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
