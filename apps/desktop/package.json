{
  "name": "@brett/desktop",
  "version": "0.0.1",
  "private": true,
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"tsc -p tsconfig.electron.json -w\" \"electron .\"",
    "electron:build": "vite build && tsc -p tsconfig.electron.json && electron-builder"
  },
  "dependencies": {
    "@brett/business": "workspace:*",
    "@brett/types": "workspace:*",
    "@brett/ui": "workspace:*",
    "@brett/utils": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.0"
  }
}
