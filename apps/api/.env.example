# Database
DATABASE_URL=postgresql://brett:brett_dev@localhost:5432/brett_dev

# Server
PORT=3001
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_SECRET=dev-secret-do-not-use-in-production

# Google OAuth — web client, used by desktop (Electron) sign-in and by
# better-auth's `/sign-in/social` route. Create under Google Cloud →
# APIs & Services → Credentials → OAuth client ID → Web application.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google OAuth — iOS client, used ONLY by the native iOS app's
# GoogleSignIn-iOS SDK. Same Google Cloud project as the web client, but a
# separate "iOS" OAuth client (bundle ID com.brett.app). iOS clients have
# no secret; security comes from bundle-ID registration + server-side
# idToken audience verification in /api/auth/ios/google/token.
GOOGLE_IOS_CLIENT_ID=

# Apple Sign-In (optional — required for iOS app)
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_BUNDLE_ID=com.brett.app
# Apple Developer Team ID (10-char string, e.g. "ABCDEF1234"). Required for
# iOS passkeys — combined with APPLE_BUNDLE_ID to produce the app identifier
# that ships in the apple-app-site-association file at
# /.well-known/apple-app-site-association. Find it at
# https://developer.apple.com/account → Membership.
APPLE_TEAM_ID=

# S3-compatible storage (Railway Object Storage in prod, MinIO locally)
# Railway gives each bucket its own endpoint + credentials.
# For local dev (MinIO), all buckets share one endpoint — set the fallback vars.
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_REGION=us-east-1

# Private bucket — user attachments, presigned URLs only, NO public access
# In prod: set PRIVATE_STORAGE_ENDPOINT, PRIVATE_STORAGE_ACCESS_KEY, PRIVATE_STORAGE_SECRET_KEY
PRIVATE_STORAGE_BUCKET=brett-private
# PRIVATE_STORAGE_ENDPOINT=
# PRIVATE_STORAGE_ACCESS_KEY=
# PRIVATE_STORAGE_SECRET_KEY=

# Public bucket — videos, backgrounds, anonymous read access
# In prod: set PUBLIC_STORAGE_ENDPOINT, PUBLIC_STORAGE_ACCESS_KEY, PUBLIC_STORAGE_SECRET_KEY
PUBLIC_STORAGE_BUCKET=brett-public
# PUBLIC_STORAGE_ENDPOINT=
# PUBLIC_STORAGE_ACCESS_KEY=
# PUBLIC_STORAGE_SECRET_KEY=

# Release bucket — desktop DMGs + auto-updater metadata
# Only needed for CI (GitHub Actions) and local pnpm release.
# RELEASE_STORAGE_ENDPOINT=
# RELEASE_STORAGE_BUCKET=brett-releases
# RELEASE_STORAGE_ACCESS_KEY=
# RELEASE_STORAGE_SECRET_KEY=

# Firebase Cloud Messaging (notifications only)
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=

# Encryption (AES-256-GCM key for encrypting OAuth tokens and API keys)
TOKEN_ENCRYPTION_KEY=  # 64-character hex string (32 bytes) — generate with: openssl rand -hex 32
# CALENDAR_TOKEN_ENCRYPTION_KEY still works as a fallback (deprecated alias)
GOOGLE_WEBHOOK_BASE_URL=        # Public URL for Google webhook delivery (e.g., https://api.brett.app)

# Embedding provider (Voyage AI) — Brett-managed, not user-provided
# Required for semantic search, related items, duplicate detection
# Get a key at https://dash.voyageai.com/
EMBEDDING_API_KEY=

# Scout search providers (service-side)
TAVILY_API_KEY=
EXA_API_KEY=

# Scout cron security (generate with: openssl rand -hex 32)
SCOUT_TICK_SECRET=change-me-to-a-long-random-string

# Admin API secret (defaults to SCOUT_TICK_SECRET if not set)
ADMIN_SECRET=

# Global budget backstop (max runs per month across all users)
SCOUT_SYSTEM_BUDGET_MONTHLY=5000

# Google Weather API (currently free — requires billing-enabled GCP project)
GOOGLE_WEATHER_API_KEY=         # Maps Platform API key with Weather API enabled

# Feedback → GitHub Issues
GITHUB_FEEDBACK_PAT=            # Fine-grained PAT with Issues R/W on the target repo
GITHUB_FEEDBACK_REPO=           # owner/repo format, e.g. brentbarkman/brett

# Newsletter ingest (Postmark inbound webhook)
# Generate with: openssl rand -hex 32
# In Postmark, set the Inbound Webhook URL to
#   https://x:$NEWSLETTER_INGEST_SECRET@api.brett.app/webhooks/email/ingest
# Postmark rewrites the user:pass into an `Authorization: Basic …` header,
# which keeps the secret out of URL paths, referrer chains, and proxy logs.
# The "x" username is a placeholder — we only check the password.
NEWSLETTER_INGEST_SECRET=
NEWSLETTER_INGEST_EMAIL=        # Forwarding address shown in Settings (e.g., ingest@brett.app)
