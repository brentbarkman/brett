# Database
DATABASE_URL=postgresql://brett:brett_dev@localhost:5432/brett_dev

# Server
PORT=3001
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_SECRET=dev-secret-do-not-use-in-production

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Railway Object Storage (S3-compatible)
# For local dev with MinIO (docker-compose):
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=brett
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_REGION=us-east-1

# Firebase Cloud Messaging (notifications only)
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=

# Encryption (AES-256-GCM key for encrypting OAuth tokens and API keys)
TOKEN_ENCRYPTION_KEY=  # 64-character hex string (32 bytes) — generate with: openssl rand -hex 32
# CALENDAR_TOKEN_ENCRYPTION_KEY still works as a fallback (deprecated alias)
GOOGLE_WEBHOOK_BASE_URL=        # Public URL for Google webhook delivery (e.g., https://api.brett.app)

# Embedding provider (Voyage AI) — Brett-managed, not user-provided
# Required for semantic search, related items, duplicate detection
# Get a key at https://dash.voyageai.com/
EMBEDDING_API_KEY=

# Scout search providers (service-side)
TAVILY_API_KEY=
EXA_API_KEY=

# Scout cron security (generate with: openssl rand -hex 32)
SCOUT_TICK_SECRET=change-me-to-a-long-random-string

# Admin API secret (defaults to SCOUT_TICK_SECRET if not set)
ADMIN_SECRET=

# Global budget backstop (max runs per month across all users)
SCOUT_SYSTEM_BUDGET_MONTHLY=5000

# Google Weather API (currently free — requires billing-enabled GCP project)
GOOGLE_WEATHER_API_KEY=         # Maps Platform API key with Weather API enabled
