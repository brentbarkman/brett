<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Group shared with BrettShareExtension. Used for the share queue
	     directory and a small UserDefaults suite that mirrors the resolved
	     API base URL so the extension doesn't need to duplicate the lookup. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.brett.app</string>
	</array>

	<!-- Keychain access group so the share extension can read the bearer
	     token the main app writes. The $(AppIdentifierPrefix) placeholder is
	     expanded by the code-signing pipeline to the Apple Team ID prefix. -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.brett.app.auth</string>
	</array>

	<!-- Associated domains — required for platform passkeys. `webcredentials:`
	     tells iOS which domain's passkeys this app participates in.

	     SERVER-SIDE REQUIREMENT: api.brett.brentbarkman.com must serve
	     /.well-known/apple-app-site-association with:
	         { "webcredentials": { "apps": ["<TeamID>.com.brett.app"] } }

	     Without the AASA file, ASAuthorization passkey registration will
	     fail at runtime (the UI surfaces "Passkey setup required..." in
	     that case). -->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>webcredentials:api.brett.brentbarkman.com</string>
	</array>
</dict>
</plist>
