node_modules
dist
build
.turbo
.env
.env.*
.env.*.local
*.tsbuildinfo
.expo
android
# Ignore Expo-generated native dirs, but not apps/ios/
/ios
apps/mobile/ios
.DS_STORE
.superpowers/

# Prisma generated client (regenerated on build)
packages/api-core/src/generated/

# Login background videos (hosted on S3, not bundled)
apps/desktop/public/videos/*.mp4

# Background images (hosted on Railway Object Storage, not bundled)
/backgrounds/

# Firebase service account keys
*-firebase-adminsdk-*.json
firebase-service-account.json
.claude/worktrees/
.claude/scheduled_tasks.lock
.claude/*.lock
.worktrees/

# Background audit local artifacts (verdicts + sourced URLs)
scripts/backgrounds/audit-results.json
scripts/backgrounds/replacement-sources.json
scripts/backgrounds/downloads/
scripts/backgrounds/downloads-portrait-src/

# Awakening-video local artifacts
scripts/awakening-videos/sources.json
scripts/awakening-videos/downloads/
apps/desktop/public/videos/awakening/

# App Store Connect API keys — never commit. The .p8 is downloadable
# exactly once from Apple, so a leak can't be revoked-and-replaced quickly.
apps/ios/fastlane/AuthKey_*.p8
apps/ios/fastlane/report.xml
apps/ios/fastlane/*.log
apps/ios/fastlane/test_output/
apps/ios/fastlane/README.md
apps/ios/build/
apps/ios/vendor/
apps/ios/.bundle/
apps/ios/*.ipa
apps/ios/*.app.dSYM.zip

# Provisioning profiles — Xcode's automatic signing fetches these on demand.
apps/desktop/build/*.provisionprofile
*.mobileprovision

# Desktop build/ is gitignored globally (root `build` rule) but we need
# the hardened-runtime entitlements file checked in for electron-builder.
# Explicitly re-ignore legacy icon duplicates — real icons live in resources/.
!apps/desktop/build/
!apps/desktop/build/entitlements.mac.plist
apps/desktop/build/icon.*
apps/ios/Brett.xcodeproj/project.pbxproj
apps/ios/Brett.xcodeproj/xcuserdata/
